{
  "name": "mom-book-engine",
  "version": "0.1.0",
  "private": true,
  "description": "Calculation core and machine-readable knowledge base derived from book.pdf",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "vite",
    "build:core": "tsc -p tsconfig.core.json",
    "typecheck:web": "tsc -p tsconfig.web.json",
    "build:web": "vite build",
    "build": "npm run build:core && npm run typecheck:web && npm run build:web",
    "preview": "vite preview",
    "validate": "tsx src/scripts/validateExamples.ts",
    "check": "npm run build && npm run validate"
  },
  "dependencies": {
    "@fontsource/atkinson-hyperlegible": "^5.2.8",
    "@tailwindcss/vite": "^4.2.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vite": "^7.1.3"
  }
}
